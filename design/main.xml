<?xml version="1.0" encoding="utf-8"?>
<Screen width="390" height="844" background="#F5F5F5">

    <!-- Header -->
    <View
        id="header"
        width="390"
        height="80"
        background="#FFFFFF"
        paddingTop="44"
        paddingLeft="20"
        paddingRight="20"
        orientation="horizontal"
        shadow="0 2 8 rgba(0,0,0,0.06)">

        <Text
            id="title"
            text="할일 캘린더"
            fontSize="20"
            fontWeight="bold"
            color="#1A1A1A" />

        <Button
            id="btn_profile"
            width="32"
            height="32"
            cornerRadius="16"
            background="#E8F0FD"
            align="right"
            icon="person"
            iconColor="#4A90E2"
            iconSize="16" />
    </View>

    <!-- Month Navigation -->
    <View
        id="month_nav"
        width="390"
        height="52"
        background="#FFFFFF"
        paddingLeft="20"
        paddingRight="20"
        orientation="horizontal"
        marginTop="1">

        <Button
            id="btn_prev_month"
            width="36"
            height="36"
            cornerRadius="18"
            background="#F5F5F5"
            icon="chevron_left"
            iconColor="#555555"
            iconSize="18" />

        <Text
            id="month_year"
            text="2026년 3월"
            fontSize="17"
            fontWeight="semibold"
            color="#1A1A1A"
            align="center"
            flex="1" />

        <Button
            id="btn_next_month"
            width="36"
            height="36"
            cornerRadius="18"
            background="#F5F5F5"
            icon="chevron_right"
            iconColor="#555555"
            iconSize="18" />
    </View>

    <!-- Color Category Legend -->
    <View
        id="legend"
        width="390"
        height="36"
        background="#FFFFFF"
        paddingLeft="20"
        paddingRight="20"
        orientation="horizontal"
        gap="16"
        marginTop="1">

        <View orientation="horizontal" gap="5">
            <View width="10" height="10" cornerRadius="5" background="#FF4444" marginTop="2" />
            <Text text="필수" fontSize="12" color="#666666" />
        </View>

        <View orientation="horizontal" gap="5">
            <View width="10" height="10" cornerRadius="5" background="#4A90E2" marginTop="2" />
            <Text text="건강" fontSize="12" color="#666666" />
        </View>

        <View orientation="horizontal" gap="5">
            <View width="10" height="10" cornerRadius="5" background="#F5A623" marginTop="2" />
            <Text text="약속" fontSize="12" color="#666666" />
        </View>

        <View orientation="horizontal" gap="5">
            <View width="10" height="10" cornerRadius="5" background="#FF69B4" marginTop="2" />
            <Text text="놀러가기" fontSize="12" color="#666666" />
        </View>

    </View>

    <!-- Calendar Grid -->
    <View
        id="calendar"
        width="390"
        background="#FFFFFF"
        paddingLeft="8"
        paddingRight="8"
        paddingBottom="8"
        marginTop="1"
        shadow="0 2 8 rgba(0,0,0,0.04)">

        <!-- Day of Week Headers -->
        <View
            id="dow_header"
            width="374"
            height="36"
            orientation="horizontal">

            <Text text="일" fontSize="12" fontWeight="medium" color="#FF4444" width="53" align="center" />
            <Text text="월" fontSize="12" fontWeight="medium" color="#888888" width="53" align="center" />
            <Text text="화" fontSize="12" fontWeight="medium" color="#888888" width="53" align="center" />
            <Text text="수" fontSize="12" fontWeight="medium" color="#888888" width="53" align="center" />
            <Text text="목" fontSize="12" fontWeight="medium" color="#888888" width="53" align="center" />
            <Text text="금" fontSize="12" fontWeight="medium" color="#888888" width="53" align="center" />
            <Text text="토" fontSize="12" fontWeight="medium" color="#4A90E2" width="53" align="center" />
        </View>

        <!-- Week 1: Mar 1~7 -->
        <View width="374" height="52" orientation="horizontal">

            <!-- Mar 1 (Sun) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="1" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 2 (Mon) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="2" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 3 (Tue) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="3" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 4 (Wed) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="4" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 5 (Thu) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="5" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 6 (Fri) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="6" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 7 (Sat) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="7" fontSize="14" color="#4A90E2" align="center" />
                <View height="6" />
            </View>
        </View>

        <!-- Week 2: Mar 8~14 -->
        <View width="374" height="52" orientation="horizontal">

            <!-- Mar 8 (Sun) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="8" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 9 (Mon) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="9" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 10 (Tue) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="10" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 11 (Wed) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="11" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 12 (Thu) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="12" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 13 (Fri) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="13" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 14 (Sat) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="14" fontSize="14" color="#4A90E2" align="center" />
                <View height="6" />
            </View>
        </View>

        <!-- Week 3: Mar 15~21 -->
        <View width="374" height="52" orientation="horizontal">

            <!-- Mar 15 (Sun) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="15" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 16 (Mon) TODAY - SELECTED -->
            <View
                width="53"
                height="52"
                orientation="vertical"
                align="center"
                background="rgba(74,144,226,0.08)"
                cornerRadius="10">
                <View
                    width="30"
                    height="30"
                    cornerRadius="15"
                    background="#4A90E2"
                    align="center">
                    <Text text="16" fontSize="14" fontWeight="bold" color="#FFFFFF" align="center" />
                </View>
                <!-- Blue dot: 5km 달리기 -->
                <View orientation="horizontal" gap="3" marginTop="2">
                    <View width="6" height="6" cornerRadius="3" background="#4A90E2" />
                </View>
            </View>

            <!-- Mar 17 (Tue) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="17" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 18 (Wed) - 5km 달리기 -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="18" fontSize="14" color="#333333" align="center" />
                <View orientation="horizontal" gap="3" marginTop="4">
                    <View width="6" height="6" cornerRadius="3" background="#4A90E2" />
                </View>
            </View>

            <!-- Mar 19 (Thu) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="19" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 20 (Fri) - 5km 달리기 -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="20" fontSize="14" color="#333333" align="center" />
                <View orientation="horizontal" gap="3" marginTop="4">
                    <View width="6" height="6" cornerRadius="3" background="#4A90E2" />
                </View>
            </View>

            <!-- Mar 21 (Sat) - 놀러가기 (pink) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="21" fontSize="14" color="#4A90E2" align="center" />
                <View orientation="horizontal" gap="3" marginTop="4">
                    <View width="6" height="6" cornerRadius="3" background="#FF69B4" />
                </View>
            </View>
        </View>

        <!-- Week 4: Mar 22~28 -->
        <View width="374" height="52" orientation="horizontal">

            <!-- Mar 22 (Sun) - 5km 달리기 -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="22" fontSize="14" color="#333333" align="center" />
                <View orientation="horizontal" gap="3" marginTop="4">
                    <View width="6" height="6" cornerRadius="3" background="#4A90E2" />
                </View>
            </View>

            <!-- Mar 23 (Mon) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="23" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 24 (Tue) - 5km 달리기 -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="24" fontSize="14" color="#333333" align="center" />
                <View orientation="horizontal" gap="3" marginTop="4">
                    <View width="6" height="6" cornerRadius="3" background="#4A90E2" />
                </View>
            </View>

            <!-- Mar 25 (Wed) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="25" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 26 (Thu) - 5km 달리기 -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="26" fontSize="14" color="#333333" align="center" />
                <View orientation="horizontal" gap="3" marginTop="4">
                    <View width="6" height="6" cornerRadius="3" background="#4A90E2" />
                </View>
            </View>

            <!-- Mar 27 (Fri) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="27" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 28 (Sat) - 5km 달리기 -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="28" fontSize="14" color="#4A90E2" align="center" />
                <View orientation="horizontal" gap="3" marginTop="4">
                    <View width="6" height="6" cornerRadius="3" background="#4A90E2" />
                </View>
            </View>
        </View>

        <!-- Week 5: Mar 29~31 -->
        <View width="374" height="52" orientation="horizontal">

            <!-- Mar 29 (Sun) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="29" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Mar 30 (Mon) - 5km 달리기 (blue) + Claude Code 50강 마감 (red) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="30" fontSize="14" color="#333333" align="center" />
                <View orientation="horizontal" gap="3" marginTop="4">
                    <View width="6" height="6" cornerRadius="3" background="#FF4444" />
                    <View width="6" height="6" cornerRadius="3" background="#4A90E2" />
                </View>
            </View>

            <!-- Mar 31 (Tue) -->
            <View width="53" height="52" orientation="vertical" align="center">
                <Text text="31" fontSize="14" color="#333333" align="center" />
                <View height="6" />
            </View>

            <!-- Empty cells for alignment -->
            <View width="53" height="52" />
            <View width="53" height="52" />
            <View width="53" height="52" />
            <View width="53" height="52" />
        </View>

    </View>

    <!-- Selected Day Todo List -->
    <View
        id="selected_day_section"
        width="390"
        marginTop="12"
        paddingLeft="20"
        paddingRight="20">

        <View orientation="horizontal" marginBottom="12">
            <Text
                text="3월 16일 (월)"
                fontSize="16"
                fontWeight="bold"
                color="#1A1A1A" />
            <Text
                text="오늘"
                fontSize="12"
                color="#4A90E2"
                background="rgba(74,144,226,0.1)"
                paddingLeft="8"
                paddingRight="8"
                paddingTop="3"
                paddingBottom="3"
                cornerRadius="10"
                marginLeft="8" />
        </View>

        <ScrollView
            id="todo_list"
            width="350"
            gap="10">

            <!-- Todo: 5km 달리기 (건강 - 파란색) -->
            <View
                id="todo_run_16"
                width="350"
                height="68"
                background="#FFFFFF"
                cornerRadius="12"
                padding="14"
                orientation="horizontal"
                shadow="0 1 4 rgba(0,0,0,0.06)">

                <!-- 분류 색상 바 -->
                <View
                    width="4"
                    height="40"
                    background="#4A90E2"
                    cornerRadius="2"
                    marginRight="12" />

                <CheckBox
                    id="check_run_16"
                    width="22"
                    height="22"
                    checked="false"
                    checkedColor="#4A90E2"
                    cornerRadius="11"
                    marginRight="10" />

                <View orientation="vertical" flex="1">
                    <Text
                        text="5km 달리기"
                        fontSize="15"
                        fontWeight="medium"
                        color="#1A1A1A" />
                    <Text
                        text="건강 · 격일 반복 (~4/10)"
                        fontSize="12"
                        color="#4A90E2"
                        marginTop="3" />
                </View>

                <!-- 수정/삭제 버튼 -->
                <Button
                    id="btn_more_run16"
                    width="28"
                    height="28"
                    icon="ellipsis"
                    iconColor="#BBBBBB"
                    iconSize="16"
                    background="transparent" />
            </View>

            <!-- Todo: 주말 나들이 (놀러가기 - 핑크색) -->
            <View
                id="todo_outing_16"
                width="350"
                height="68"
                background="#FFFFFF"
                cornerRadius="12"
                padding="14"
                orientation="horizontal"
                shadow="0 1 4 rgba(0,0,0,0.06)">

                <!-- 분류 색상 바 -->
                <View
                    width="4"
                    height="40"
                    background="#FF69B4"
                    cornerRadius="2"
                    marginRight="12" />

                <CheckBox
                    id="check_outing_16"
                    width="22"
                    height="22"
                    checked="false"
                    checkedColor="#FF69B4"
                    cornerRadius="11"
                    marginRight="10" />

                <View orientation="vertical" flex="1">
                    <Text
                        text="주말 나들이"
                        fontSize="15"
                        fontWeight="medium"
                        color="#1A1A1A" />
                    <Text
                        text="놀러가기"
                        fontSize="12"
                        color="#FF69B4"
                        marginTop="3" />
                </View>

                <!-- 수정/삭제 버튼 -->
                <Button
                    id="btn_more_outing16"
                    width="28"
                    height="28"
                    icon="ellipsis"
                    iconColor="#BBBBBB"
                    iconSize="16"
                    background="transparent" />
            </View>

        </ScrollView>
    </View>

    <!-- FAB (할일 추가) -->
    <Button
        id="fab_add"
        width="56"
        height="56"
        cornerRadius="28"
        background="#4A90E2"
        icon="plus"
        iconColor="#FFFFFF"
        iconSize="24"
        shadow="0 4 16 rgba(74,144,226,0.45)"
        align="bottomRight"
        marginBottom="96"
        marginRight="24" />

    <!-- Add Todo Modal (시트 형태, 기본은 숨김) -->
    <View
        id="add_todo_sheet"
        width="390"
        height="420"
        background="#FFFFFF"
        cornerRadius_topLeft="20"
        cornerRadius_topRight="20"
        align="bottom"
        shadow="0 -4 20 rgba(0,0,0,0.12)"
        padding="24"
        visible="false">

        <!-- 핸들 바 -->
        <View
            width="40"
            height="4"
            background="#E0E0E0"
            cornerRadius="2"
            align="center"
            marginBottom="20" />

        <Text
            text="할일 추가"
            fontSize="18"
            fontWeight="bold"
            color="#1A1A1A"
            marginBottom="20" />

        <!-- 제목 입력 -->
        <TextField
            id="input_title"
            width="342"
            height="48"
            placeholder="할일을 입력하세요"
            fontSize="15"
            color="#1A1A1A"
            background="#F5F5F5"
            cornerRadius="10"
            paddingLeft="14"
            marginBottom="14" />

        <!-- 날짜 선택 -->
        <View
            id="date_picker_row"
            width="342"
            height="48"
            background="#F5F5F5"
            cornerRadius="10"
            paddingLeft="14"
            paddingRight="14"
            orientation="horizontal"
            marginBottom="14">
            <Text text="날짜" fontSize="14" color="#888888" flex="1" />
            <Text text="2026. 3. 16" fontSize="14" color="#1A1A1A" />
            <Icon name="chevron_right" size="16" color="#BBBBBB" marginLeft="4" />
        </View>

        <!-- 분류 선택 -->
        <View
            id="category_row"
            width="342"
            height="48"
            orientation="horizontal"
            gap="8"
            marginBottom="20">

            <Button
                id="cat_must"
                text="필수"
                fontSize="13"
                fontWeight="medium"
                color="#FF4444"
                background="rgba(255,68,68,0.1)"
                paddingLeft="12"
                paddingRight="12"
                height="36"
                cornerRadius="18"
                borderWidth="1.5"
                borderColor="#FF4444" />

            <Button
                id="cat_health"
                text="건강"
                fontSize="13"
                fontWeight="medium"
                color="#888888"
                background="#F0F0F0"
                paddingLeft="12"
                paddingRight="12"
                height="36"
                cornerRadius="18" />

            <Button
                id="cat_promise"
                text="약속"
                fontSize="13"
                fontWeight="medium"
                color="#888888"
                background="#F0F0F0"
                paddingLeft="12"
                paddingRight="12"
                height="36"
                cornerRadius="18" />

            <Button
                id="cat_outing"
                text="놀러가기"
                fontSize="13"
                fontWeight="medium"
                color="#888888"
                background="#F0F0F0"
                paddingLeft="12"
                paddingRight="12"
                height="36"
                cornerRadius="18" />

        </View>

        <!-- 저장 버튼 -->
        <Button
            id="btn_save"
            width="342"
            height="52"
            text="저장하기"
            fontSize="16"
            fontWeight="semibold"
            color="#FFFFFF"
            background="#4A90E2"
            cornerRadius="14" />

    </View>

    <!-- Bottom Navigation Bar -->
    <View
        id="bottom_nav"
        width="390"
        height="80"
        background="#FFFFFF"
        align="bottom"
        paddingBottom="16"
        orientation="horizontal"
        shadow="0 -1 8 rgba(0,0,0,0.06)">

        <NavItem
            id="nav_home"
            icon="home"
            label="홈"
            color="#AAAAAA"
            selected="false"
            width="97" />

        <NavItem
            id="nav_calendar"
            icon="calendar"
            label="캘린더"
            color="#4A90E2"
            selected="true"
            width="97" />

        <NavItem
            id="nav_stats"
            icon="chart"
            label="통계"
            color="#AAAAAA"
            selected="false"
            width="97" />

        <NavItem
            id="nav_settings"
            icon="settings"
            label="설정"
            color="#AAAAAA"
            selected="false"
            width="97" />
    </View>

</Screen>
